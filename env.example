# Copy this file to .env.local and fill in your actual Supabase values
# .env.local is gitignored and will NOT be uploaded to GitHub

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Render backend URL — your RotaCatScheduler service URL on Render
# e.g. https://rotacatscheduler.onrender.com
VITE_SCHEDULER_URL=https://your-render-service.onrender.com
